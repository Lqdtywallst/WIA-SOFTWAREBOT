# App
APP_NAME=TradingView IG Bot
# Use paper to simulate orders locally, demo to send orders to IG demo, live for IG live.
TRADING_MODE=demo
LOG_LEVEL=INFO

# Optional shared secret. If set, TradingView alerts must include this value as "secret".
WEBHOOK_SECRET=

# Risk management
RISK_PER_TRADE=0.01
MAX_TRADES_PER_DAY=3
MAX_DAILY_LOSS=500.0
ACCOUNT_EQUITY=10000.0
DEFAULT_STOP_DISTANCE=20.0
DEFAULT_TAKE_PROFIT_DISTANCE=40.0
DEFAULT_DEAL_SIZE=1.0

# Signal filters (equities defaults above). For IG crypto CFDs try e.g.:
# MAX_DIST_VWAP_ATR=6
# MIN_LONG_SCORE=6
# MIN_SHORT_SCORE=6
# DEFAULT_STOP_DISTANCE / DEFAULT_TAKE_PROFIT_DISTANCE in *points* for that epic (BTC vs ETH differ).
MAX_DIST_VWAP_ATR=4.0
MIN_LONG_SCORE=7.0
MIN_SHORT_SCORE=7.0
REJECT_ON_RANGO_STATE=true
REJECT_ON_NO_CHASE_STATE=true

# Optional: TradingView ticker -> symbol used for risk/order logs (and IG epic when not in paper). JSON object, single line.
# Example: SYMBOL_MAP={"ZECUSDT":"ZECUSDT"}
SYMBOL_MAP=

# IG Markets
IG_API_KEY=your-api-key
IG_IDENTIFIER=your-identifier
IG_PASSWORD=your-password
IG_ACCOUNT_TYPE=demo
IG_ACCOUNT_ID=
